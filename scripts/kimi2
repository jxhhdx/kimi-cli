#!/usr/bin/env python3
#
# kimi2 - 魔改版 Kimi CLI 启动脚本
#
# 用法: kimi2 [所有 kimi 支持的参数]
#
# 示例:
#   kimi2                    # 交互式模式
#   kimi2 --print -y -p "任务"  # 非交互式
#   kimi2 mail test          # 测试邮件配置
#

import sys
import os

# 魔改版路径
KIMI_CUSTOM_DIR = "/Users/gaoxiang/Workspace2026/kimi-cli"

# 检查路径
if not os.path.isdir(KIMI_CUSTOM_DIR):
    print(f"Error: 魔改版 kimi-cli 未找到: {KIMI_CUSTOM_DIR}")
    sys.exit(1)

# 添加魔改版 src 到 Python 路径
sys.path.insert(0, os.path.join(KIMI_CUSTOM_DIR, "src"))

# 导入并运行 CLI
from kimi_cli.cli import cli

if __name__ == "__main__":
    cli()
