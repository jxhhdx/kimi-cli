```mermaid
%%{init: {'theme': 'base'}}%%
classDiagram
    class KimiToolset {
        -_tool_dict: dict
        -_hidden_tools: set
        -_mcp_servers: dict
        +add(tool)
        +handle(tool_call)
        +load_tools(paths, deps)
        +load_mcp_tools(configs)
    }
    
    class Context {
        -_history: list[Message]
        -_token_count: int
        -_file_backend: Path
        -_next_checkpoint_id: int
        +restore()
        +append_message(msg)
        +checkpoint()
        +revert_to(id)
        +clear()
    }
    
    class KimiSoul {
        -_agent: Agent
        -_context: Context
        -_runtime: Runtime
        -_compaction: Compaction
        +run(user_input)
        -_agent_loop()
        -_step()
    }
    
    class DenwaRenji {
        -_pending_dmail: DMail
        -_n_checkpoints: int
        +send_dmail(dmail)
        +fetch_pending_dmail()
    }
    
    class SimpleCompaction {
        -max_preserved_messages: int
        +compact(messages, llm)
        -prepare(messages)
    }
    
    KimiSoul --> Context
    KimiSoul --> KimiToolset
    KimiSoul --> DenwaRenji
    KimiSoul --> SimpleCompaction
```
