#!/bin/bash
#
# kimi2 - 完整的魔改版 Kimi CLI
#
# 使用 Python 3.12 运行魔改版代码
# 功能与官方 kimi 完全一致，增加邮件通知
#

# Python 3.12
PYTHON="/Library/Frameworks/Python.framework/Versions/3.12/bin/python3.12"

# 检查 Python 3.12
if [[ ! -x "$PYTHON" ]]; then
    echo "Error: Python 3.12 未找到: $PYTHON"
    echo "请安装 Python 3.12"
    exit 1
fi

# 魔改版路径
export KIMI_DIR="/Users/gaoxiang/Workspace2026/kimi-cli"

# 邮件配置（从环境变量读取，如果不存在则使用默认值）
export KIMI_EMAIL_ADDRESS="${KIMI_EMAIL_ADDRESS:-1490960584@qq.com}"
export KIMI_EMAIL_PASSWORD="${KIMI_EMAIL_PASSWORD:-iemigwydobhjbagh}"
export KIMI_NOTIFY_EMAIL="${KIMI_NOTIFY_EMAIL:-igaoxian@foxmail.com}"

# 运行魔改版
exec "$PYTHON" -c "
import sys
sys.path.insert(0, '$KIMI_DIR/src')
sys.path.insert(0, '$KIMI_DIR/packages/kaos/src')
sys.path.insert(0, '$KIMI_DIR/packages/kosong/src')
sys.path.insert(0, '$KIMI_DIR/packages/kimi-code/src')

from kimi_cli.cli import cli
cli()
" "$@"
